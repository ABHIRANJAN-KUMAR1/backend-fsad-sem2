VITE_API_URL=https://your-render-service.onrender.com/api
# Frontend public runtime configuration template
# Copy to .env for local development.

# Use /api when running with Vite proxy, or set full backend URL when hosted separately.
VITE_API_URL=/api

# Public Builder key (not a secret). Keep as placeholder unless Builder.io is used.
VITE_PUBLIC_BUILDER_KEY=your-public-builder-key

PING_MESSAGE=ping pong
