PORT=10000
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=replace-with-strong-secret
CORS_ALLOWED_ORIGINS=https://your-vercel-project.vercel.app,https://*.vercel.app

# Render Postgres (auto-injected if using render.yaml database link)
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=

# Optional mail setup
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply-sac@college.edu
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_STRICT_DELIVERY=false
